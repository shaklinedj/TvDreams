# Frontend URL (for shared user credentials and login links)
# For production, you can use a domain without port like: https://yourdomain.com
# For development with custom port: http://localhost:5173
# For development without port (if using reverse proxy): http://localhost
FRONTEND_URL=http://172.20.80.220:3001

# DISPLAY_API_BASE_URL y DISPLAY_WS_URL NO se definen aquí:
# El servidor las genera automáticamente desde req.hostname por cada request,
# así cada display recibe la URL correcta según la IP por la que accedió.
# Si necesitas forzar una IP específica, descomenta estas líneas:
# DISPLAY_API_BASE_URL=http://172.20.80.220:3001
# DISPLAY_WS_URL=ws://172.20.80.220:3001

# External WebSocket URL for premio messages.  This is used by the server
# when constructing links/etc.  The client uses VITE_PREMIO_WS_URL instead.
PREMIO_WS_URL=WS://172.20.82.222:3001

# set the client-side value with the VITE_ prefix (full ws:// URL allowed):
VITE_PREMIO_WS_URL=ws://172.20.82.222:3001

