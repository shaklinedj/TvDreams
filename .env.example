# JWT Secret Key
# This key is used to sign and verify JSON Web Tokens.
# It should be a long, random, and secret string.
JWT_SECRET=a-very-secret-and-secure-key-that-you-should-change

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cms_usuarios_jules

# Gmail API Configuration (optional)
# Get these from Google Cloud Console for Gmail API
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_USER=your-email@gmail.com

# Alternative: Gmail App Password (simpler setup)
GMAIL_APP_PASSWORD=your-app-specific-password

# Frontend URL (for email links and shared URLs)
FRONTEND_URL=http://localhost:5173